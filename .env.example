# ── Database ────────────────────────────────────────────────────────────────
DB_URL=mongodb://localhost:27017/

# ── Optional API providers ──────────────────────────────────────────────────
# Leave blank for fully local food detection.
FOOD_API_KEY=
MODEL_ID=
OPENAI_API_KEY=

# ── Food detection mode ─────────────────────────────────────────────────────
# auto   = local-first + API augmentation when keys exist
# api    = prefer API; still falls back to local if API unavailable
# local  = local only
FOOD_PROVIDER=auto

# Local model settings
LOCAL_FOOD_MODEL_PATH=models/food/yolov8n-food101-cls.pt
LOCAL_FOOD_MODEL_FALLBACK_PATH=yolov8n-cls.pt
LOCAL_FOOD_TOPK=5
LOCAL_FOOD_CONFIDENCE=0.08
FOOD_MIN_CONFIDENCE=0.08
FOOD_MIN_INTERVAL_S=2.5

# ── App behavior flags ──────────────────────────────────────────────────────
CAMMY_ENABLE_NEW_COLLECTION_WRITES=1
# 1 = faster reload/start in dev by skipping PANN warmup
CAMMY_SKIP_PANN_WARMUP=1
# 1 = show asyncio WinError 10054 reset logs on Windows
CAMMY_LOG_ASYNCIO_RESET=0

# ── Audio tuning (optional) ─────────────────────────────────────────────────
PANN_INPUT_GAIN=1.42
PANN_HOP_FRACTION=0.60
PANN_QUEUE_MAXSIZE=12
PANN_QUEUE_HIGH_WATERMARK=0.7
PANN_WINDOW_PEAK_GATE=0.065
PANN_WINDOW_PEAK_TARGET=0.32
